{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Glob",
      "Grep",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskStop",
      "TaskGet",
      "TaskOutput",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "autoMemoryEnabled": true,
  "autoMemoryDirectory": "~/.claude/projects/LoveTI/memory/",
  "respectGitignore": false,
  "language": "zh-CN"
}
